<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tracker.Views.EditTaskPage"
             xmlns:viewmodels="clr-namespace:Tracker.ViewModels"
             x:DataType="viewmodels:EditTaskViewModel">

    <Grid RowDefinitions="*,Auto">
        <!-- Scrollable Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="10">
            
            <!-- Task Name -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Task Name" FontAttributes="Bold"/>
                <Entry Text="{Binding TaskName}" Placeholder="Enter task name"/>
            </VerticalStackLayout>

            <!-- Description -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Description" FontAttributes="Bold"/>
                <Editor Text="{Binding Description}" 
                        Placeholder="Enter description (optional)"
                        HeightRequest="250"/>
            </VerticalStackLayout>

            <!-- Toggles and Pickers Row -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15">
                <!-- Due Date Column -->
                <VerticalStackLayout Grid.Column="0" Spacing="5">
                    <Label Text="Due Date" FontAttributes="Bold" FontSize="14"/>
                    <HorizontalStackLayout Spacing="0">
                        <Switch IsToggled="{Binding HasDueDate}"
                                VerticalOptions="Center"
                                Margin="0,0,5,0"/>
                        <DatePicker Date="{Binding DueDate}"
                                  Format="dd/MM/yyyy"
                                  IsEnabled="{Binding HasDueDate}"
                                  VerticalOptions="Center"
                                  WidthRequest="120"
                                  Margin="-75,0,0,0"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Reminders Column -->
                <VerticalStackLayout Grid.Column="1" Spacing="5">
                    <Label Text="Reminders" FontAttributes="Bold" FontSize="14"/>
                    <HorizontalStackLayout Spacing="0">
                        <Switch IsToggled="{Binding HasReminders}"
                                VerticalOptions="Center"/>
                        <TimePicker Time="{Binding ReminderTime}"
                                  Format="HH:mm"
                                  IsEnabled="{Binding HasReminders}"
                                  VerticalOptions="Center"
                                  HorizontalOptions="Center"
                                  FontSize="12"
                                  Margin="-75,0,0,-15"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Auto-complete Column -->
                <VerticalStackLayout Grid.Column="2" Spacing="5">
                    <Label Text="Auto-complete" FontAttributes="Bold" FontSize="14"/>
                    <HorizontalStackLayout Spacing="0">
                        <Switch IsToggled="{Binding AutoCompleteWithSubtasks}"
                                VerticalOptions="Center"/>
                        <Label Text="Completes task if all subtasks are completed"
                               FontSize="11"
                               LineBreakMode="WordWrap"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               Margin="-75,0,0,0"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>

            <!-- Priority -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Priority" FontAttributes="Bold" FontSize="16"/>
                <Picker ItemsSource="{Binding Priorities}"
                        SelectedItem="{Binding SelectedPriority}"/>
            </VerticalStackLayout>

            <!-- Subtasks -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Subtasks" FontAttributes="Bold" FontSize="16"/>
                
                <CollectionView ItemsSource="{Binding Subtasks}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:SubtaskItem">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,5">
                                <Entry Grid.Column="0"
                                       Text="{Binding Name}"
                                       Placeholder="Subtask name"/>
                                <Button Grid.Column="1"
                                        Text="✕"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:EditTaskViewModel}}, Path=RemoveSubtaskCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource Primary}"
                                        FontSize="18"
                                        Padding="10,0"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="+ Add Subtask" 
                        Command="{Binding AddSubtaskCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
    
    <!-- Fixed Buttons at Bottom -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10" Padding="10" BackgroundColor="{StaticResource OffBlack}">
        <Button Grid.Column="0" 
                Text="Cancel"
                Command="{Binding CancelCommand}"
                BackgroundColor="{StaticResource Gray300}"
                TextColor="{StaticResource Gray900}"
                WidthRequest="100"
                HorizontalOptions="Center"/>
        <Button Grid.Column="1" 
                Text="Save"
                Command="{Binding SaveCommand}"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                WidthRequest="100"
                HorizontalOptions="Center"/>
    </Grid>
</Grid>
</ContentPage>
