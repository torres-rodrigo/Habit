<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tracker.Views.EditTaskPage"
             xmlns:viewmodels="clr-namespace:Tracker.ViewModels"
             x:DataType="viewmodels:EditTaskViewModel">

    <Grid RowDefinitions="*,Auto">
        <!-- Scrollable Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="7" Spacing="10">
            
            <!-- Task Name -->
            <VerticalStackLayout Spacing="5">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="Task Name" FontAttributes="Bold" FontSize="17"/>
                    <Label Grid.Column="1"
                           Text="{Binding CreatedDateFormatted, StringFormat='Created: {0}'}"
                           FontSize="14"
                           TextColor="{StaticResource Gray500}"
                           VerticalOptions="Center"
                           HorizontalOptions="End"
                           IsVisible="{Binding IsEditingExistingTask}"/>
                </Grid>
                <Entry Text="{Binding TaskName}" Placeholder="Enter task name"/>
            </VerticalStackLayout>

            <!-- Description -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Description" FontAttributes="Bold" FontSize="17"/>
                <Editor Text="{Binding Description}" 
                        Placeholder="Enter description (optional)"
                        HeightRequest="250"/>
            </VerticalStackLayout>

            <!-- Due Date -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Due Date" FontAttributes="Bold" FontSize="17"/>
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding HasDueDate}"
                            VerticalOptions="Center"/>
                    <DatePicker Date="{Binding DueDate}"
                              Format="dd/MM/yyyy"
                              IsEnabled="{Binding HasDueDate}"
                              VerticalOptions="Center"
                              Margin="-110, 0"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Reminders -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Reminders" FontAttributes="Bold" FontSize="17"/>
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding HasReminders}"
                            VerticalOptions="Center"
                            Margin="0, 0, 0, 10"/>
                    <TimePicker Time="{Binding ReminderTime}"
                              Format="HH:mm"
                              IsEnabled="{Binding HasReminders}"
                              VerticalOptions="Center"
                              Margin="-110, 0, 0, 0"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Auto-complete -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Auto-complete" FontAttributes="Bold" FontSize="17"/>
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding AutoCompleteWithSubtasks}"
                            VerticalOptions="Center"
                            Margin="0,0,0,0"/>
                    <Label Text="Completes task if all subtasks are completed"
                           FontSize="14"
                           LineBreakMode="WordWrap"
                           VerticalOptions="Center"
                           Margin="-110, 0, 0, 3"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Priority -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Priority" FontAttributes="Bold" FontSize="17"/>
                <Picker ItemsSource="{Binding Priorities}"
                        SelectedItem="{Binding SelectedPriority}"/>
            </VerticalStackLayout>

            <!-- Subtasks -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Subtasks" FontAttributes="Bold" FontSize="17"/>

                <CollectionView ItemsSource="{Binding Subtasks}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:SubtaskItem">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,5">
                                <Entry Grid.Column="0"
                                       Text="{Binding Name}"
                                       Placeholder="Subtask name"/>
                                <Button Grid.Column="1"
                                        Text="✕"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:EditTaskViewModel}}, Path=RemoveSubtaskCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource Primary}"
                                        FontSize="18"
                                        Padding="10,0"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="+ Add Subtask"
                        Command="{Binding AddSubtaskCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>

            <!-- Action Buttons (only visible when editing) -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding IsEditingExistingTask}">
                <Button Text="🗑️ Delete"
                        Command="{Binding DeleteCommand}"
                        BackgroundColor="Red"
                        TextColor="White"
                        HorizontalOptions="Fill"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
    
    <!-- Fixed Buttons at Bottom -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10" Padding="10" BackgroundColor="{StaticResource OffBlack}">
        <Button Grid.Column="0" 
                Text="Cancel"
                Command="{Binding CancelCommand}"
                BackgroundColor="{StaticResource Gray300}"
                TextColor="{StaticResource Gray900}"
                WidthRequest="100"
                HorizontalOptions="Center"/>
        <Button Grid.Column="1" 
                Text="Save"
                Command="{Binding SaveCommand}"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                WidthRequest="100"
                HorizontalOptions="Center"/>
    </Grid>
</Grid>
</ContentPage>
