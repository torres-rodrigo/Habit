<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Tracker.ViewModels"
             xmlns:models="clr-namespace:Tracker.Models"
             x:Class="Tracker.Views.StatisticsPage"
             x:DataType="viewmodels:StatisticsViewModel"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="7" Spacing="5">

            <!-- Task Statistics Section -->
            <Label FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#FF8C00"
                   VerticalOptions="Center">
                <Label.Text>
                    <MultiBinding StringFormat="{}{0} Task Statistics">
                        <Binding Path="IsTaskStatisticsCollapsed" Converter="{StaticResource BoolToCollapseIconConverter}" />
                    </MultiBinding>
                </Label.Text>
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleTaskStatisticsCollapseCommand}"/>
                </Label.GestureRecognizers>
            </Label>

            <Frame CornerRadius="10" BorderColor="#FF8C00" HasShadow="True"
                   IsVisible="{Binding IsTaskStatisticsCollapsed, Converter={StaticResource InvertedBoolConverter}}">
                <VerticalStackLayout Spacing="10">

                    <!-- All time Section -->
                    <Label Text="All time"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#FF8C00"/>

                    <VerticalStackLayout Spacing="2">
                        <Grid ColumnDefinitions="85,*,105" ColumnSpacing="5">
                            <Label Grid.Column="0"
                                   Text="Total Tasks:"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                            <ProgressBar Grid.Column="1"
                                       Progress="{Binding TaskStatistics.Progress}"
                                       ProgressColor="#FF8C00"
                                       VerticalOptions="Center"/>
                            <Label Grid.Column="2"
                                   Text="{Binding TaskStatistics.CompletionRate, StringFormat='({0:F0}%)'}"
                                   TextColor="#FF8C00"
                                   FontAttributes="Bold"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Label HorizontalOptions="End"
                               FontAttributes="Bold"
                               Margin="0,0,8,0">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}/{1}">
                                    <Binding Path="TaskStatistics.CompletedTasks" />
                                    <Binding Path="TaskStatistics.TotalTasks" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="5" RowSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="Tasks w/ Deadlines:" FontAttributes="Bold"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding TaskStatistics.TasksWithDeadlines}" HorizontalOptions="End"/>
                        
                        <Label Grid.Row="1" Grid.Column="0" Text="Completed On Time:" FontAttributes="Bold"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding TaskStatistics.CompletedOnTime}" HorizontalOptions="End"/>
                        <Label Grid.Row="1" Grid.Column="2"
                               Text="{Binding TaskStatistics.OnTimeRate, StringFormat='({0:F0}%)'}"
                               TextColor="#FF8C00"
                               FontAttributes="Bold"
                               HorizontalOptions="End"
                               Margin="5,0,0,0"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="Completed Overdue:" FontAttributes="Bold"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding TaskStatistics.CompletedAfterDeadline}" HorizontalOptions="End"/>
                        <Label Grid.Row="2" Grid.Column="2"
                               Text="{Binding TaskStatistics.LateRate, StringFormat='({0:F0}%)'}"
                               TextColor="#FF8C00"
                               FontAttributes="Bold"
                               HorizontalOptions="End"
                               Margin="5,0,0,0"/>
                    </Grid>

                    <!-- Yearly Breakdown -->
                    <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,10"/>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding TaskStatistics.YearlyBreakdown}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:YearlyTaskStatistics">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding Year}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#FF8C00"/>

                                    <Grid ColumnDefinitions="85,*,50,50" ColumnSpacing="5">
                                        <Label Grid.Column="0"
                                               Text="Total Tasks:"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"/>
                                        <ProgressBar Grid.Column="1"
                                                   Progress="{Binding Progress}"
                                                   ProgressColor="#FF8C00"
                                                   VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center"
                                               Margin="0,0,-10,0">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0}/{1}">
                                                    <Binding Path="CompletedTasks" />
                                                    <Binding Path="TotalTasks" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label Grid.Column="3"
                                               Text="{Binding CompletionRate, StringFormat='({0:F0}%)'}"
                                               TextColor="#FF8C00"
                                               FontAttributes="Bold"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="5">
                                        <Label Grid.Column="0"
                                               Text="Completed Overdue:"
                                               FontAttributes="Bold"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding CompletedOverdue}"
                                               HorizontalOptions="End"/>
                                        <Label Grid.Column="2"
                                               TextColor="#FF8C00"
                                               FontAttributes="Bold"
                                               HorizontalOptions="End"
                                               Margin="5,0,0,0">
                                            <Label.Text>
                                                <MultiBinding StringFormat="({0:F0}%)">
                                                    <Binding Path="CompletedOverdueRate" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,10,0,0"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Habit Statistics Section -->
            <Label FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#FF8C00"
                   VerticalOptions="Center">
                <Label.Text>
                    <MultiBinding StringFormat="{}{0} Habit Statistics">
                        <Binding Path="IsHabitStatisticsCollapsed" Converter="{StaticResource BoolToCollapseIconConverter}" />
                    </MultiBinding>
                </Label.Text>
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleHabitStatisticsCollapseCommand}"/>
                </Label.GestureRecognizers>
            </Label>

            <!-- Active Habits -->
            <CollectionView ItemsSource="{Binding ActiveHabitStatistics}" SelectionMode="None"
                            IsVisible="{Binding IsHabitStatisticsCollapsed, Converter={StaticResource InvertedBoolConverter}}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="5"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:HabitStatistics">
                        <Frame CornerRadius="10"
                               BorderColor="#FF8C00"
                               HasShadow="True"
                               Margin="0"
                               Padding="15">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="{Binding HabitName}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#FF8C00"/>

                                <!-- Daily -->
                                <Grid ColumnDefinitions="85,*,55,50" ColumnSpacing="5">
                                    <Label Grid.Column="0" Text="Today:" FontAttributes="Bold"/>
                                    <ProgressBar Grid.Column="1"
                                               Progress="{Binding DailyCompletions}"
                                               ProgressColor="#FF8C00"
                                               VerticalOptions="Center"/>
                                    <Label Grid.Column="2"
                                         Text="{Binding DailyCompletions, StringFormat='{0}/1'}"
                                         HorizontalOptions="End"/>
                                    <Label Grid.Column="3"
                                         Text="{Binding DailyCompletions, StringFormat='({0:P0})'}"
                                         TextColor="#FF8C00"
                                         FontAttributes="Bold"
                                         HorizontalOptions="End"/>
                                </Grid>

                                <!-- Weekly -->
                                <Grid ColumnDefinitions="85,*,55,50" ColumnSpacing="5">
                                    <Label Grid.Column="0" Text="Week:" FontAttributes="Bold"/>
                                    <ProgressBar Grid.Column="1"
                                               Progress="{Binding WeeklyProgress}"
                                               ProgressColor="#FF8C00"
                                               VerticalOptions="Center"/>
                                    <Label Grid.Column="2"
                                         HorizontalOptions="End">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0}/{1}">
                                                <Binding Path="WeeklyCompletions" />
                                                <Binding Path="WeeklyTarget" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Label Grid.Column="3"
                                         Text="{Binding WeeklyProgress, StringFormat='({0:P0})'}"
                                         TextColor="#FF8C00"
                                         FontAttributes="Bold"
                                         HorizontalOptions="End"/>
                                </Grid>

                                <!-- Monthly -->
                                <Grid ColumnDefinitions="85,*,55,50" ColumnSpacing="5">
                                    <Label Grid.Column="0" Text="Month:" FontAttributes="Bold"/>
                                    <ProgressBar Grid.Column="1"
                                               Progress="{Binding MonthlyProgress}"
                                               ProgressColor="#FF8C00"
                                               VerticalOptions="Center"/>
                                    <Label Grid.Column="2"
                                         HorizontalOptions="End">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0}/{1}">
                                                <Binding Path="MonthlyCompletions" />
                                                <Binding Path="MonthlyTarget" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Label Grid.Column="3"
                                         Text="{Binding MonthlyProgress, StringFormat='({0:P0})'}"
                                         TextColor="#FF8C00"
                                         FontAttributes="Bold"
                                         HorizontalOptions="End"/>
                                </Grid>

                                <!-- Yearly -->
                                <Grid ColumnDefinitions="85,*,55,50" ColumnSpacing="5">
                                    <Label Grid.Column="0" Text="Year:" FontAttributes="Bold"/>
                                    <ProgressBar Grid.Column="1"
                                               Progress="{Binding YearlyProgress}"
                                               ProgressColor="#FF8C00"
                                               VerticalOptions="Center"/>
                                    <Label Grid.Column="2"
                                         HorizontalOptions="End">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0}/{1}">
                                                <Binding Path="YearlyCompletions" />
                                                <Binding Path="YearlyTarget" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Label Grid.Column="3"
                                           Text="{Binding YearlyProgress, StringFormat='({0:P0})'}"
                                           TextColor="#FF8C00"
                                           FontAttributes="Bold"
                                           HorizontalOptions="End"/>
                                </Grid>

                                <!-- All Time -->
                                <VerticalStackLayout Spacing="2">
                                    <Grid ColumnDefinitions="85,*,110" ColumnSpacing="5">
                                        <Label Grid.Column="0" Text="All Time:" FontAttributes="Bold" VerticalOptions="Center"/>
                                        <ProgressBar Grid.Column="1"
                                                   Progress="{Binding AllTimeProgress}"
                                                   ProgressColor="#FF8C00"
                                                   VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding AllTimeProgress, StringFormat='({0:P0})'}"
                                               TextColor="#FF8C00"
                                               FontAttributes="Bold"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                    <Label HorizontalOptions="End"
                                           FontAttributes="Bold"
                                           Margin="0,0,8,0">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0}/{1}">
                                                <Binding Path="AllTimeCompletions" />
                                                <Binding Path="AllTimeExpected" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Current Streak:" FontAttributes="Bold"/>
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding CurrentStreak, StringFormat='{0} days'}" HorizontalOptions="End"/>

                                    <Label Grid.Row="1" Grid.Column="0" Text="Longest Streak:" FontAttributes="Bold"/>
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding LongestStreak, StringFormat='{0} days'}" HorizontalOptions="End"/>

                                    <!--<Label Grid.Row="2" Grid.Column="0" Text="Overall Rate:" FontAttributes="Bold"/>
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding CompletionRate, StringFormat='{0:F1}%'}" HorizontalOptions="End"/>-->
                                </Grid>

                                <!-- Yearly Breakdown -->
                                <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,10"/>

                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding YearlyBreakdown}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:YearlyHabitStatistics">
                                            <VerticalStackLayout Spacing="8">
                                                <Label Text="{Binding Year}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="#FF8C00"/>

                                                <Grid ColumnDefinitions="85,*,50,50" ColumnSpacing="5">
                                                    <Label Grid.Column="0"
                                                           Text="Progress:"
                                                           FontAttributes="Bold"
                                                           VerticalOptions="Center"/>
                                                    <ProgressBar Grid.Column="1"
                                                               Progress="{Binding Progress}"
                                                               ProgressColor="#FF8C00"
                                                               VerticalOptions="Center"/>
                                                    <Label Grid.Column="2"
                                                           HorizontalOptions="End"
                                                           VerticalOptions="Center"
                                                           Margin="0,0,-10,0">
                                                        <Label.Text>
                                                            <MultiBinding StringFormat="{}{0}/{1}">
                                                                <Binding Path="CompletedDays" />
                                                                <Binding Path="ExpectedDays" />
                                                            </MultiBinding>
                                                        </Label.Text>
                                                    </Label>
                                                    <Label Grid.Column="3"
                                                           Text="{Binding CompletionRate, StringFormat='({0:F0}%)'}"
                                                           TextColor="#FF8C00"
                                                           FontAttributes="Bold"
                                                           HorizontalOptions="End"
                                                           VerticalOptions="Center"/>
                                                </Grid>

                                                <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,10,0,0"/>
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                                <!--<BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,5"/>-->
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Completed Habits Subsection -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding HasCompletedHabits}">
                <Label FontSize="22"
                       FontAttributes="Bold"
                       TextColor="Green"
                       VerticalOptions="Center"
                       Margin="0,10,0,0">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0} Completed">
                            <Binding Path="IsCompletedHabitsCollapsed" Converter="{StaticResource BoolToCollapseIconConverter}" />
                        </MultiBinding>
                    </Label.Text>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleCompletedHabitsCollapseCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

                <CollectionView ItemsSource="{Binding CompletedHabitStatistics}" SelectionMode="None"
                                IsVisible="{Binding IsCompletedHabitsCollapsed, Converter={StaticResource InvertedBoolConverter}}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="5"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:HabitStatistics">
                            <Frame CornerRadius="10"
                                   BorderColor="Green"
                                   HasShadow="True"
                                   Margin="0"
                                   Padding="15">
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="{Binding HabitName}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="Green"/>

                                    <!-- Daily -->
                                    <Grid ColumnDefinitions="85,*,55,50" ColumnSpacing="5">
                                        <Label Grid.Column="0" Text="Today:" FontAttributes="Bold"/>
                                        <ProgressBar Grid.Column="1"
                                                   Progress="{Binding DailyCompletions}"
                                                   ProgressColor="Green"
                                                   VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                             Text="{Binding DailyCompletions, StringFormat='{0}/1'}"
                                             HorizontalOptions="End"/>
                                        <Label Grid.Column="3"
                                             Text="{Binding DailyCompletions, StringFormat='({0:P0})'}"
                                             TextColor="Green"
                                             FontAttributes="Bold"
                                             HorizontalOptions="End"/>
                                    </Grid>

                                    <!-- Weekly -->
                                    <Grid ColumnDefinitions="85,*,55,50" ColumnSpacing="5">
                                        <Label Grid.Column="0" Text="Week:" FontAttributes="Bold"/>
                                        <ProgressBar Grid.Column="1"
                                                   Progress="{Binding WeeklyProgress}"
                                                   ProgressColor="Green"
                                                   VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                             HorizontalOptions="End">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0}/{1}">
                                                    <Binding Path="WeeklyCompletions" />
                                                    <Binding Path="WeeklyTarget" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label Grid.Column="3"
                                             Text="{Binding WeeklyProgress, StringFormat='({0:P0})'}"
                                             TextColor="Green"
                                             FontAttributes="Bold"
                                             HorizontalOptions="End"/>
                                    </Grid>

                                    <!-- Monthly -->
                                    <Grid ColumnDefinitions="85,*,55,50" ColumnSpacing="5">
                                        <Label Grid.Column="0" Text="Month:" FontAttributes="Bold"/>
                                        <ProgressBar Grid.Column="1"
                                                   Progress="{Binding MonthlyProgress}"
                                                   ProgressColor="Green"
                                                   VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                             HorizontalOptions="End">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0}/{1}">
                                                    <Binding Path="MonthlyCompletions" />
                                                    <Binding Path="MonthlyTarget" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label Grid.Column="3"
                                             Text="{Binding MonthlyProgress, StringFormat='({0:P0})'}"
                                             TextColor="Green"
                                             FontAttributes="Bold"
                                             HorizontalOptions="End"/>
                                    </Grid>

                                    <!-- Yearly -->
                                    <Grid ColumnDefinitions="85,*,55,50" ColumnSpacing="5">
                                        <Label Grid.Column="0" Text="Year:" FontAttributes="Bold"/>
                                        <ProgressBar Grid.Column="1"
                                                   Progress="{Binding YearlyProgress}"
                                                   ProgressColor="Green"
                                                   VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                             HorizontalOptions="End">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0}/{1}">
                                                    <Binding Path="YearlyCompletions" />
                                                    <Binding Path="YearlyTarget" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label Grid.Column="3"
                                             Text="{Binding YearlyProgress, StringFormat='({0:P0})'}"
                                             TextColor="Green"
                                             FontAttributes="Bold"
                                             HorizontalOptions="End"/>
                                    </Grid>

                                    <!-- All Time -->
                                    <VerticalStackLayout Spacing="2">
                                        <Grid ColumnDefinitions="85,*,110" ColumnSpacing="5">
                                            <Label Grid.Column="0" Text="All Time:" FontAttributes="Bold" VerticalOptions="Center"/>
                                            <ProgressBar Grid.Column="1"
                                                       Progress="{Binding AllTimeProgress}"
                                                       ProgressColor="Green"
                                                       VerticalOptions="Center"/>
                                            <Label Grid.Column="2"
                                                   Text="{Binding AllTimeProgress, StringFormat='({0:P0})'}"
                                                   TextColor="Green"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="End"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                        <Label HorizontalOptions="End"
                                               FontAttributes="Bold"
                                               Margin="0,0,8,0">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0}/{1}">
                                                    <Binding Path="AllTimeCompletions" />
                                                    <Binding Path="AllTimeExpected" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                    </VerticalStackLayout>

                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                                        <Label Grid.Row="0" Grid.Column="0" Text="Current Streak:" FontAttributes="Bold"/>
                                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding CurrentStreak, StringFormat='{0} days'}" HorizontalOptions="End"/>

                                        <Label Grid.Row="1" Grid.Column="0" Text="Longest Streak:" FontAttributes="Bold"/>
                                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding LongestStreak, StringFormat='{0} days'}" HorizontalOptions="End"/>
                                    </Grid>

                                    <!-- Yearly Breakdown -->
                                    <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,10"/>

                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding YearlyBreakdown}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:YearlyHabitStatistics">
                                                <VerticalStackLayout Spacing="8">
                                                    <Label Text="{Binding Year}"
                                                           FontSize="16"
                                                           FontAttributes="Bold"
                                                           TextColor="Green"/>

                                                    <Grid ColumnDefinitions="85,*,50,50" ColumnSpacing="5">
                                                        <Label Grid.Column="0"
                                                               Text="Progress:"
                                                               FontAttributes="Bold"
                                                               VerticalOptions="Center"/>
                                                        <ProgressBar Grid.Column="1"
                                                                   Progress="{Binding Progress}"
                                                                   ProgressColor="Green"
                                                                   VerticalOptions="Center"/>
                                                        <Label Grid.Column="2"
                                                               HorizontalOptions="End"
                                                               VerticalOptions="Center"
                                                               Margin="0,0,-10,0">
                                                            <Label.Text>
                                                                <MultiBinding StringFormat="{}{0}/{1}">
                                                                    <Binding Path="CompletedDays" />
                                                                    <Binding Path="ExpectedDays" />
                                                                </MultiBinding>
                                                            </Label.Text>
                                                        </Label>
                                                        <Label Grid.Column="3"
                                                               Text="{Binding CompletionRate, StringFormat='({0:F0}%)'}"
                                                               TextColor="Green"
                                                               FontAttributes="Bold"
                                                               HorizontalOptions="End"
                                                               VerticalOptions="Center"/>
                                                    </Grid>

                                                    <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,10,0,0"/>
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Untracked Habits Subsection -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding HasUntrackedHabits}">
                <Label FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#FFC107"
                       VerticalOptions="Center"
                       Margin="0,10,0,0">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0} Untracked">
                            <Binding Path="IsUntrackedHabitsCollapsed" Converter="{StaticResource BoolToCollapseIconConverter}" />
                        </MultiBinding>
                    </Label.Text>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleUntrackedHabitsCollapseCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

                <Frame CornerRadius="10"
                       BorderColor="#FFC107"
                       HasShadow="True"
                       Margin="0"
                       Padding="15"
                       IsVisible="{Binding IsUntrackedHabitsCollapsed, Converter={StaticResource InvertedBoolConverter}}">
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding UntrackedHabitsByYear}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:YearUntrackedCount">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding Year}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#FFC107"/>

                                    <Grid ColumnDefinitions="Auto,*,50,50" ColumnSpacing="5">
                                        <Label Grid.Column="0"
                                               Text="Untracked:"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center"
                                               Margin="0,0,-10,0">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0}/{1}">
                                                    <Binding Path="UntrackedCount" />
                                                    <Binding Path="TotalCount" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label Grid.Column="3"
                                               Text="{Binding Percentage, StringFormat='({0:F0}%)'}"
                                               TextColor="#FFC107"
                                               FontAttributes="Bold"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center"/>
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="{StaticResource Gray300}" Margin="0,10,0,0"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
