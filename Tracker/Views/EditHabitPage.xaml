<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Tracker.ViewModels"
             x:Class="Tracker.Views.EditHabitPage"
             x:DataType="viewmodels:EditHabitViewModel">

    <Grid RowDefinitions="*,Auto">
        <!-- Scrollable Content -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20">
            
            <!-- Habit Name -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Habit Name" FontAttributes="Bold"/>
                <Entry Text="{Binding Name}" Placeholder="Enter habit name"/>
            </VerticalStackLayout>

            <!-- Description -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Description" FontAttributes="Bold"/>
                <Editor Text="{Binding Description}" 
                        Placeholder="Enter description (optional)"
                        HeightRequest="250"/>
            </VerticalStackLayout>

            <!-- Tracking Days -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Tracking Schedule" FontAttributes="Bold" FontSize="16"/>
                
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding TrackEveryday}"/>
                    <Label Text="Track Everyday" VerticalOptions="Center" Margin="-110,0"/>
                </HorizontalStackLayout>

                <VerticalStackLayout Spacing="5" IsVisible="{Binding TrackEveryday, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="Select Days:" FontAttributes="Bold"/>
                    <CollectionView ItemsSource="{Binding DaysOfWeek}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:DayOfWeekItem">
                                <HorizontalStackLayout Spacing="10" Margin="0,5">
                                    <CheckBox IsChecked="{Binding IsSelected}" Color="{StaticResource Primary}"/>
                                    <Label Text="{Binding Name}" VerticalOptions="Center" Margin="-15,0"/>
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- Reminders -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Reminders" FontAttributes="Bold" FontSize="16"/>

                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding HasReminders}"/>
                    <Label Text="Enable Reminders" VerticalOptions="Center" Margin="-110, 0"/>
                </HorizontalStackLayout>

                <TimePicker Time="{Binding ReminderTime}" 
                            IsVisible="{Binding HasReminders}"
                            Format="HH:mm"/>
            </VerticalStackLayout>

            <!-- Deadline -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Deadline" FontAttributes="Bold" FontSize="16"/>
                
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding HasDeadline}"/>
                    <Label Text="Set Deadline" VerticalOptions="Center" Margin="-110, 0"/>
                </HorizontalStackLayout>

                <DatePicker Date="{Binding Deadline}" 
                            IsVisible="{Binding HasDeadline}"/>
            </VerticalStackLayout>

            <!-- Negative Habit -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Negative Habit" FontAttributes="Bold" FontSize="16"/>

                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding IsNegativeHabit}"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Notes -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Notes" FontAttributes="Bold" FontSize="16"/>

                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding NotesEnabled}"/>
                    <Label Text="Enable Daily Notes" VerticalOptions="Center" Margin="-110, 0"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Action Buttons (only visible when editing) -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding IsEditingExistingHabit}">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <!-- Untrack/Track Button -->
                    <Button Grid.Column="0"
                            Text="{Binding UntrackTrackButtonText}"
                            Command="{Binding UntrackTrackCommand}"
                            BackgroundColor="{Binding UntrackTrackButtonColor}"
                            TextColor="White"
                            WidthRequest="200"/>

                    <!-- Delete Button -->
                    <Button Grid.Column="1"
                            Text="🗑️ Delete"
                            Command="{Binding DeleteCommand}"
                            BackgroundColor="Red"
                            TextColor="White"
                            WidthRequest="200"/>
                </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
    
    <!-- Fixed Buttons at Bottom -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10" Padding="15" BackgroundColor="{StaticResource OffBlack}">
        <Button Grid.Column="0" 
                Text="Cancel"
                Command="{Binding CancelCommand}"
                BackgroundColor="{StaticResource Gray300}"
                TextColor="{StaticResource Gray900}"
                WidthRequest="150"
                HorizontalOptions="Center"/>
        <Button Grid.Column="1" 
                Text="Save"
                Command="{Binding SaveCommand}"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                WidthRequest="150"
                HorizontalOptions="Center"/>
    </Grid>
</Grid>
</ContentPage>
